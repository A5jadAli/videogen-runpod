# ============================================================
# Required — No defaults, must be set
# ============================================================

# RunPod API key (Settings → API Keys)
RUNPOD_API_KEY=your_runpod_api_key_here

# HuggingFace token (optional but recommended to avoid rate limits)
HF_TOKEN=hf_your_token_here

# Digital Ocean Spaces credentials
DIGITAL_OCEAN_ENDPOINT_URL=https://sfo3.digitaloceanspaces.com
DIGITAL_OCEAN_BUCKET_ACCESS_KEY=your_spaces_access_key
DIGITAL_OCEAN_BUCKET_SECRET_KEY=your_spaces_secret_key
DIGITAL_OCEAN_BUCKET_NAME=your-bucket-name
DIGITAL_OCEAN_BUCKET_URL=https://your-bucket-name.sfo3.cdn.digitaloceanspaces.com/
